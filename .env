# Файл со ссылками на подписки (каждая ссылка с новой строки)
SUB_FILE="subs.txt"
# Лимит количества создаваемых SOCKS5 прокси (0 = без лимита)
MAX_PROXIES=50
# Настройки SOCKS5 прокси
SOCKS_USER="my_secure_user"
SOCKS_PASS="my_secure_password"
START_PORT=10001
# Путь к бинарнику xray
XRAY_BIN="xray"
RECHECK_INTERVAL=60
BATCH_SIZE=150
